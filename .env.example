# ============================================
# Heavy Haul Move Control - Environment Variables
# ============================================
# For Vercel deployment (Client-Side Supabase Architecture)
# ============================================

# Supabase Configuration
# Get these from your Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# IMPORTANT:
# - SUPABASE_URL: Your Supabase project URL (safe to expose)
# - SUPABASE_ANON_KEY: Your anon key (safe to expose in browser, restricted by RLS)
# - DO NOT use SERVICE_ROLE_KEY in this architecture!
# - The anon key is restricted by Row Level Security policies

# Discord Notification Configuration (optional)
# To receive notifications in your Discord channel when someone submits a move:
# Get this from Discord → Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ============================================
# DEPLOYMENT NOTES
# ============================================
# 1. Set these variables in Vercel Dashboard → Settings → Environment Variables
# 2. Select "Production", "Preview", and "Development" environments
# 3. Redeploy after setting variables
# 4. For local development, create a .env file from this template
# ============================================
